PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=replace-with-a-long-random-value

# Copy the current values from your Meta developer app documentation.
INSTAGRAM_APP_ID=your-app-id
INSTAGRAM_APP_SECRET=your-app-secret
INSTAGRAM_REDIRECT_URI=http://localhost:4000/api/auth/instagram/callback
INSTAGRAM_OAUTH_AUTHORIZE_URL=https://replace-with-current-official-authorize-endpoint
INSTAGRAM_OAUTH_TOKEN_URL=https://replace-with-current-official-token-endpoint
INSTAGRAM_SCOPES=replace-with-current-approved-scopes
INSTAGRAM_GRAPH_BASE_URL=https://replace-with-current-graph-base-and-version
